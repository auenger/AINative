{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri-v2-docs/refs/heads/1.x/config.schema.json",
  "productName": "Neuro Syntax IDE",
  "version": "0.1.0",
  "identifier": "com.neuro-syntax.ide",
  "build": {
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Neuro Syntax IDE",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/skill-bundle"
    ]
  },
  "plugins": {}
}
